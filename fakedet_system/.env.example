# Copy to .env (it is auto-loaded). The system runs on the LOCAL box;
# only the trained model needs a GPU and lives behind FAKEDET_BACKEND_URL.

# ---- External intent LLM -------------------------------------------------
# provider: "gemini" (default) or "openai" (any OpenAI-compatible endpoint:
# Groq, Together, vLLM, ...). Leave the key empty to fall back to the
# offline keyword heuristic (the system still runs, just no LLM intent).
# Same external model is used for BOTH intent classification AND for
# answering the text_to_detect / user_guide intents (with context, and the
# previous image re-attached for deeper analysis).
FAKEDET_INTENT_PROVIDER=gemini
# put your key in .env (gitignored), NOT here
FAKEDET_INTENT_API_KEY=
FAKEDET_INTENT_MODEL=gemini-2.5-flash
# only used when provider=openai
FAKEDET_INTENT_BASE_URL=https://api.openai.com/v1
FAKEDET_INTENT_TIMEOUT_S=20
FAKEDET_EXTERNAL_MAX_TOKENS=512

# ---- Trained FakeDet model backend ---------------------------------------
# Two slots, both optional but at least one must work:
#   FAKEDET_BACKEND_URL       -> default backend (e.g. HF Space, 24/7).
#   FAKEDET_BACKEND_URL_COLAB -> optional Colab tunnel (fast, ephemeral).
# When _COLAB is set, open-webui shows THREE models in its dropdown:
#   fakedet-v1.2            -> HF Space, vision v1
#   fakedet-v1.2-colab      -> Colab, vision v1
#   fakedet-v1.2-v2-colab   -> Colab, vision v2
# Switch backend/version per chat by picking the model — no Docker restart.
FAKEDET_BACKEND_URL=http://localhost:8000/v1
FAKEDET_BACKEND_URL_COLAB=
FAKEDET_BACKEND_KEY=sk-fakedet
FAKEDET_MODEL_NAME=fakedet-vlm
FAKEDET_MODEL_NAME_V2=fakedet-vlm-v2
FAKEDET_BACKEND_TIMEOUT_S=120

# ---- Memory (SQLite, local) ----------------------------------------------
FAKEDET_MEMORY_DB=./runs/fakedet_memory.sqlite
FAKEDET_MEMORY_TURNS=8

# ---- This service's model id (shown in open-webui's model dropdown) ------
FAKEDET_SYSTEM_MODEL_ID=fakedet-v1.2

# ---- Langfuse (pipeline tracing) -----------------------------------------
# Leave keys blank to disable. First-run flow:
#   1. docker compose up -d   (brings up langfuse + db)
#   2. open http://localhost:3000  → sign up locally → create project
#   3. Settings → API keys → "Create new" → copy pk-lf-... and sk-lf-...
#   4. paste them here, then  docker compose restart fakedet-system
# LANGFUSE_HOST is set by compose to http://langfuse:3000 in-network.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
